// Custom styles.

// MathJax 样式优化
.MathJax {
  font-size: 1.05em !important;
}

// 行内公式优化
.has-jax {
  overflow-x: auto;
  overflow-y: hidden;
}

// 块级公式优化
.MathJax_Display {
  margin: 0.8em 0 !important;
  overflow-x: auto;
  overflow-y: hidden;
}

// 公式容器优化
.MathJax_Preview {
  color: #888;
  font-style: italic;
}
