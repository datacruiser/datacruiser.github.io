// Custom styles.

// MathJax 渲染优化 - 防止闪烁
.MathJax_Preview {
  visibility: hidden;
}

// MathJax 渲染完成后显示
.MathJax {
  opacity: 0;
  transition: opacity 0.3s ease-in-out;
}

.MathJax.Processed {
  opacity: 1;
}

// 行内公式优化
.has-jax {
  overflow-x: auto;
  overflow-y: hidden;
}

// 块级公式优化
.MathJax_Display {
  margin: 1em 0 !important;
  overflow-x: auto;
  overflow-y: hidden;
}
